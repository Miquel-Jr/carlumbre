{
  "name": "carlumbre/app",
  "scripts": {
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "@composer dump-autoload",
      "@php -S 0.0.0.0:8000 -t public"
    ]
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Core/Helpers.php"
    ]
  },
  "require": {
    "vlucas/phpdotenv": "^5.6",
    "dompdf/dompdf": "^3.1",
    "ext-gd": "*",
    "cloudinary/cloudinary_php": "^3.1"
  }
}
